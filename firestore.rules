rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER FUNCTIONS ──────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // SECURITY: Use memberUids flat array for efficient membership check
    function isFamilyMember(familyId) {
      let fam = get(/databases/$(database)/documents/families/$(familyId)).data;
      // Check memberUids first (new field), fallback to members array (legacy)
      let memberUids = fam != null ? fam.get('memberUids', fam.get('members', [])) : [];
      return isSignedIn()
        && fam != null
        && request.auth.uid in memberUids;
    }

    function isFamilyOwner(familyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/families/$(familyId))
        && get(/databases/$(database)/documents/families/$(familyId)).data.primaryOwner == request.auth.uid;
    }

    // ── USER DOCUMENTS ────────────────────────────────────────────
    // Each user can only read and write their own user doc.

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId; // SECURITY: uid must match doc ID
      allow update: if isOwner(userId)
        && request.resource.data.uid == userId; // SECURITY: cannot change uid
      allow delete: if false; // SECURITY: never delete user docs via client
    }

    // ── FAMILY DOCUMENTS ──────────────────────────────────────────
    // Only members can read. Only owner can change membership/roles.

    match /families/{familyId} {
      allow read: if isFamilyMember(familyId);

      allow create: if isSignedIn()
        && request.resource.data.primaryOwner == request.auth.uid
        && request.resource.data.memberUids.hasAll([request.auth.uid])
        && request.resource.data.memberUids.size() == 1; // SECURITY: creator only on creation

      allow update: if isFamilyMember(familyId)
        // SECURITY: Members cannot change ownership
        && request.resource.data.primaryOwner == resource.data.primaryOwner
        // SECURITY: Only owner can change memberUids
        && (request.resource.data.get('memberUids', []) == resource.data.get('memberUids', [])
            || isFamilyOwner(familyId));

      allow delete: if false; // SECURITY: never delete families via client

      // ── SUBCOLLECTIONS ────────────────────────────────────────

      match /expenses/{docId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId)
          && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
      }

      match /tasks/{docId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId)
          && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
      }

      match /reminders/{docId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId)
          && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
      }

      match /kidEvents/{docId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId)
          && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
      }

      match /autoExpenses/{docId} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyMember(familyId);
      }

      match /appLogs/{docId} {
        allow read: if isFamilyOwner(familyId);
        allow create: if isFamilyMember(familyId);
        allow update, delete: if false;
      }

      // ── HEALTH PROFILES ────────────────────────────────────────
      // Health data: stricter. Only family members can read.

      match /healthProfiles/{profileId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId)
          && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));

        match /reports/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
          
          // Additional pages for multi-page reports
          match /pages/{pageId} {
            allow read: if isFamilyMember(familyId);
            allow create: if isFamilyMember(familyId);
            allow delete: if isFamilyMember(familyId);
          }
        }

        match /medications/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }

        match /vitals/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }

        match /doseLogs/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId);
        }

        match /visits/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }

        match /bills/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }

        match /timeline/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if false; // timeline is immutable
          allow delete: if isFamilyOwner(familyId);
        }

        match /notes/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }

        match /chatHistory/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if false;
          allow delete: if isFamilyOwner(familyId);
        }

        match /reminders/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId);
        }
        
        match /symptoms/{docId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId)
            && (resource.data.createdBy == request.auth.uid || isFamilyOwner(familyId));
        }
      }
    }

    // ── SHARED HEALTH PROFILES (Collection Group) ────────────────
    // Allows users to query all healthProfiles where they are in sharedWith array
    match /{path=**}/healthProfiles/{profileId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.get('sharedWith', []);
    }
    
    // Subcollections of shared health profiles (must be separate rules)
    match /{path=**}/healthProfiles/{profileId}/reports/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
      
      // Multi-page report pages
      match /pages/{pageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
      }
    }
    
    match /{path=**}/healthProfiles/{profileId}/medications/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/vitals/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/visits/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/bills/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/timeline/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/doseLogs/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/notes/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/chatHistory/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/reminders/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }
    
    match /{path=**}/healthProfiles/{profileId}/symptoms/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/$(path)/healthProfiles/$(profileId)).data.get('sharedWith', []);
    }

    // ── INVITATIONS ───────────────────────────────────────────────
    // Invitations can be read by anyone (needed to validate before login)
    // Created by Cloud Function only (client cannot create)

    match /invitations/{inviteId} {
      allow read: if true; // SECURITY: must be readable before auth to join
      allow create: if false; // SECURITY: only Cloud Function can create
      allow update: if false; // SECURITY: immutable (Cloud Function marks as used)
      allow delete: if isSignedIn()
        && (resource.data.createdBy == request.auth.uid
            || isFamilyOwner(resource.data.familyId));
    }

    // ── SHARED HEALTH ACCESS ──────────────────────────────────────
    // Time-limited read-only health record sharing with non-members

    match /sharedHealthAccess/{shareId} {
      allow read: if true; // validated in app before showing data
      allow create: if isSignedIn()
        && request.resource.data.sharedBy == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.sharedBy == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.sharedBy == request.auth.uid;
    }

    // ── APP LOGS ──────────────────────────────────────────────────
    match /appLogs/{docId} {
      allow read: if false; // only readable by Cloud Functions
      allow create: if isSignedIn(); // any user can log crashes
      allow update, delete: if false;
    }

    // ── DENY EVERYTHING ELSE ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
