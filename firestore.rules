rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User document — each user can read/write their own doc (login bootstrap, setup, join)
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Helper: user is a member (in members array OR in memberProfiles)
    function isFamilyMember(familyId) {
      let fam = get(/databases/$(database)/documents/families/$(familyId)).data;
      let members = fam != null ? fam.get('members', []) : [];
      let memberProfiles = fam != null ? fam.get('memberProfiles', {}) : {};
      return request.auth != null
        && fam != null
        && (request.auth.uid in members || request.auth.uid in memberProfiles);
    }

    // Family document — any authenticated user can read
    // their own family doc (needed for login bootstrap)
    match /families/{familyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Subcollections — authenticated members only (members array OR memberProfiles)
      match /expenses/{doc} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /tasks/{doc} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /reminders/{doc} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /autoExpenses/{doc} {
        allow read, write: if isFamilyMember(familyId);
      }

      match /healthProfiles/{profileId} {
        allow read, write: if isFamilyMember(familyId);
        match /{subcollection}/{doc} {
          allow read, write: if isFamilyMember(familyId);
        }
      }

      // Rate limit state — written only by Cloud Functions (server-side admin SDK bypasses rules)
      match /_rateLimits/{doc} {
        allow read, write: if false;
      }
    }

    // Invitations — created by Cloud Function (createInvite); anyone with code can read; joiner or creator can update
    match /invitations/{code} {
      allow create: if false;
      allow read: if true;
      allow update: if request.auth != null
        && (request.resource.data.used == true
            || request.auth.uid == resource.data.createdBy);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }
  }
}
