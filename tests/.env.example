# FamilyOS Health Tests — Environment Variables
# Copy this file to tests/.env and fill in values

# Firebase project (required for seed + E2E)
FIREBASE_PROJECT_ID=familyos-e3d4b

# Path to Firebase Admin SDK service account JSON
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# The Firestore family document ID (copy from Firestore → families collection)
FAMILY_ID=your_family_id_here

# Deployed app URL for E2E tests
APP_URL=https://familyos-e3d4b.web.app

# E2E options
HEADLESS=true           # false = show browser window (useful for debugging)
SLOW_MO=0               # ms delay between Puppeteer actions (50-100 for visual debugging)
E2E_TIMEOUT=20000       # ms per assertion

# Optional: skip login step if running against pre-authenticated session
SKIP_LOGIN=false
